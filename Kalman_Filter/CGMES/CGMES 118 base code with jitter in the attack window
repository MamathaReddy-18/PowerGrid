# I2) SUPERVISED DETECTOR (HistGradientBoosting)                         [CHANGE]
# =============================================================================
def train_histgb_classifier(df_all: pd.DataFrame):
    feat_cols = ["chi2", "ang_abs_mean", "ang_abs_max", "mag_abs_mean", "mag_abs_max"]
    sim_ids = np.sort(df_all["sim_id"].unique())
    k = int(np.ceil(0.7*len(sim_ids)))
    train_sims, test_sims = sim_ids[:k], sim_ids[k:]

    train_mask = df_all["sim_id"].isin(train_sims)
    test_mask  = df_all["sim_id"].isin(test_sims)

    X_train = df_all.loc[train_mask, feat_cols].to_numpy()
    y_train = df_all.loc[train_mask, "label"].astype(int).to_numpy()
    X_test  = df_all.loc[test_mask, feat_cols].to_numpy() if test_mask.any() else None
    y_test  = df_all.loc[test_mask, "label"].astype(int).to_numpy() if test_mask.any() else None

    clf = HistGradientBoostingClassifier(
        max_depth=3, learning_rate=0.12, max_iter=300,
        min_samples_leaf=20, l2_regularization=1.0,
        random_state=BASE_SEED,
    )
    clf.fit(X_train, y_train)

    proba_train = clf.predict_proba(X_train)[:,1]
    proba_all = np.zeros(len(df_all), dtype=float)
    proba_all[train_mask] = proba_train
    if test_mask.any():
        proba_all[test_mask] = clf.predict_proba(X_test)[:,1]

    base_mask_train = train_mask & (df_all["t"] <= PRETRAIN_END)
    ml_thr = float(np.percentile(proba_all[base_mask_train], DET_PERC_GLOBAL)) if base_mask_train.any() else 0.5

    df_all = df_all.copy()
    df_all["hgb_proba"] = proba_all
    df_all["hgb_pred_attack"] = (proba_all > ml_thr).astype(int)

    if test_mask.any():
        y_pred = df_all.loc[test_mask, "hgb_pred_attack"].to_numpy()
        tp = int(((y_pred==1) & (y_test==1)).sum())
        precision = tp / max(1, int((y_pred==1).sum()))
        recall    = tp / max(1, int((y_test==1).sum()))
        f1 = 0.0 if (precision+recall)==0 else 2*precision*recall/(precision+recall)
        print(f"[HGB] Train sims={len(train_sims)} Test sims={len(test_sims)} | Thr={ml_thr:.3f}")
        print(f"[HGB] Precision={precision:.3f} Recall={recall:.3f} F1={f1:.3f}")
    else:
        print(f"[HGB] Train sims={len(train_sims)} (no held-out sims). Thr={ml_thr:.3f}")

    return clf, ml_thr, df_all


