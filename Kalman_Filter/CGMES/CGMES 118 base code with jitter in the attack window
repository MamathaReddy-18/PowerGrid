_DEF_GAP = DEBOUNCE_GAP

def _debounce(indices: list[int], gap: int = _DEF_GAP) -> list[int]:
    out, last = [], -10**9
    for t in sorted(indices):
        if t - last >= gap:
            out.append(t)
            last = t
    return out

def _attack_windows_from_labels(dfx: pd.DataFrame) -> list[tuple[int,int]]:
    wins, t, y = [], dfx["t"].to_numpy(), dfx["label"].to_numpy().astype(int)
    if len(t) == 0: return wins
    start = None
    for i in range(len(t)):
        if y[i] == 1 and start is None:
            start = t[i]
        if (y[i] == 0 and start is not None) or (i == len(t)-1 and start is not None):
            end_t = t[i] if y[i] == 0 else (t[i] + 1)
            wins.append((int(start), int(end_t)))
            start = None
    return wins

def plot_panels(df_all: pd.DataFrame, sid: int, if_thr: float, hgb_thr: float | None = None):
    dfx = df_all[df_all.sim_id == sid].copy()
    t = dfx["t"].to_numpy()
    wins = _attack_windows_from_labels(dfx)

    fig, ax = plt.subplots(3, 1, figsize=(12,9), sharex=True)

    # Panel 1: χ²
    chi = dfx["chi2"].to_numpy()
    base_mask = t <= PRETRAIN_END
    chi_thr = float(np.percentile(chi[base_mask], DET_PERC_GLOBAL)) if base_mask.any() else np.nan
    chi_dets = _debounce([int(tt) for tt, v in zip(t, chi) if (tt > PRETRAIN_END and np.isfinite(v) and v > chi_thr)], _DEF_GAP)

    ax[0].plot(t, chi, lw=2.0, label="χ² residual energy")
    for i,(a,b) in enumerate(wins): ax[0].axvspan(a, b, color="#5b9bd5", alpha=0.18, label="attack window" if i==0 else None)
    if np.isfinite(chi_thr): ax[0].axhline(chi_thr, ls="--", lw=1.6, color="#1f77b4", alpha=0.8, label=f"χ² thr p{DET_PERC_GLOBAL}")
    for i,tt in enumerate(chi_dets): ax[0].axvline(tt, color="#ff7f0e", lw=1.6, alpha=0.85, label="χ² detect" if i==0 else None)
    ax[0].set_title("Global residual energy (Mahalanobis)")
    ax[0].set_ylabel("χ²"); ax[0].grid(True, alpha=0.3); ax[0].legend()

    # Panel 2: Isolation Forest
    if "if_score" in dfx.columns:
        if_score = dfx["if_score"].to_numpy()
        if_dets = _debounce([int(tt) for tt, s in zip(t, if_score) if (tt > PRETRAIN_END and s < if_thr)], _DEF_GAP)
        ax[1].plot(t, if_score, lw=2.0, label="IF score (higher=normal)")
        for i,(a,b) in enumerate(wins): ax[1].axvspan(a, b, color="#5b9bd5", alpha=0.18, label="attack window" if i==0 else None)
        ax[1].axhline(if_thr, ls="--", lw=1.6, color="#9467bd", alpha=0.9, label="IF threshold")
        for i,tt in enumerate(if_dets): ax[1].axvline(tt, color="#8a2be2", lw=1.6, alpha=0.85, label="IF detect" if i==0 else None)
        ax[1].set_ylabel("IF score"); ax[1].grid(True, alpha=0.3); ax[1].legend()
    else:
        ax[1].axis("off")

    # Panel 3: HGB
    if "hgb_proba" in dfx.columns:
        hgb = dfx["hgb_proba"].to_numpy()
        if hgb_thr is None:
            hgb_thr = float(np.percentile(hgb[t <= PRETRAIN_END], DET_PERC_GLOBAL)) if (t <= PRETRAIN_END).any() else 0.5
        hgb_dets = _debounce([int(tt) for tt, p in zip(t, hgb) if (tt > PRETRAIN_END and p > hgb_thr)], _DEF_GAP)
        ax[2].plot(t, hgb, lw=2.0, label="HGB P(attack)")
        for i,(a,b) in enumerate(wins): ax[2].axvspan(a, b, color="#5b9bd5", alpha=0.18, label="attack window" if i==0 else None)
        ax[2].axhline(hgb_thr, ls="--", lw=1.6, color="#2ca02c", alpha=0.9, label="HGB threshold")
        for i,tt in enumerate(hgb_dets): ax[2].axvline(tt, color="#2ca02c", lw=1.6, alpha=0.85, label="HGB detect" if i==0 else None)
        ax[2].set_xlabel("Time step")
        ax[2].set_ylabel("P(attack)"); ax[2].grid(True, alpha=0.3); ax[2].legend()
    else:
        ax[2].axis("off")

    plt.tight_layout(); plt.show()


