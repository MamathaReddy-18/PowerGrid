def train_isolation_forest(df_all: pd.DataFrame):
    feat_cols = ["chi2", "ang_abs_mean", "ang_abs_max", "mag_abs_mean", "mag_abs_max"]
    baseline_mask = df_all["t"] <= PRETRAIN_END
    X_base = df_all.loc[baseline_mask, feat_cols].to_numpy()

    model = IsolationForest(
        n_estimators=300, max_samples="auto", contamination="auto", random_state=BASE_SEED
    )
    model.fit(X_base)

    scores = model.score_samples(df_all[feat_cols].to_numpy())  # higher = more normal
    df_all = df_all.copy()
    df_all["if_score"] = scores

    thr = np.percentile(scores[baseline_mask], 100 - DET_PERC_GLOBAL)
    df_all["if_pred_attack"] = (scores < thr).astype(int)

    # Simple metrics
    y_true = df_all["label"].to_numpy()
    y_pred = df_all["if_pred_attack"].to_numpy()
    tp = int(((y_pred == 1) & (y_true == 1)).sum())
    precision = tp / max(1, int((y_pred == 1).sum()))
    recall    = tp / max(1, int((y_true == 1).sum()))
    f1 = 0.0 if (precision+recall)==0 else 2*precision*recall/(precision+recall)

    print(f"[IFOREST] Baseline threshold (p{100-DET_PERC_GLOBAL} of baseline) = {thr:.4f}")
    print(f"[IFOREST] Precision={precision:.3f} Recall={recall:.3f} F1={f1:.3f}")

    return model, thr, df_all


