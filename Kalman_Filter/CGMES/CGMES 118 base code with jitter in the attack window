def validate_and_load_csv(path: Path, max_seconds: int) -> tuple[pd.DataFrame, list[str], list[str], list[str], list[str], bool]:
    if not path.is_file():
        raise FileNotFoundError(f"CSV not found: {path}")

    df = pd.read_csv(path)
    if "time_s" not in df.columns:
        raise ValueError("CSV must contain column 'time_s'.")
    df = df.sort_values("time_s").reset_index(drop=True)
    df = df[df["time_s"] < df["time_s"].iloc[0] + max_seconds].reset_index(drop=True)

    load_p_cols = sorted([c for c in df.columns if c.startswith("P_MW_bus")], key=lambda s: int(s.split("bus")[-1]))
    load_q_cols = sorted([c for c in df.columns if c.startswith("Q_MVAr_bus")], key=lambda s: int(s.split("bus")[-1]))
    gen_p_cols  = sorted([c for c in df.columns if c.startswith("Pgen_MW_bus")], key=lambda s: int(s.split("bus")[-1]))
    vset_cols   = sorted([c for c in df.columns if c.startswith("Vset_pu_bus")], key=lambda s: int(s.split("bus")[-1]))
    has_slack   = "Vset_pu_slack" in df.columns

    p_b = {int(c.split("bus")[-1]) for c in load_p_cols}
    q_b = {int(c.split("bus")[-1]) for c in load_q_cols}
    if p_b != q_b:
        missing_p = q_b - p_b
        missing_q = p_b - q_b
        if missing_p:
            raise ValueError(f"CSV Q_MVAr buses {sorted(missing_p)} have no matching P_MW entries.")
        if missing_q:
            raise ValueError(f"CSV P_MW buses {sorted(missing_q)} have no matching Q_MVAr entries.")

    # Sanity on values: NaNs → error (we prefer explicit inputs)
    if df[load_p_cols + load_q_cols].isna().any().any():
        raise ValueError("CSV has NaNs in P/Q load columns.")
    if gen_p_cols and df[gen_p_cols].isna().any().any():
        raise ValueError("CSV has NaNs in generator P columns.")
    return df, load_p_cols, load_q_cols, gen_p_cols, vset_cols, has_slack


def load_cgmes(boundary_zip: Path, basecase_zip: Path):
    for f in (boundary_zip, basecase_zip):
        if not f.is_file():
            raise FileNotFoundError(
                f"Missing CGMES file: {f}\n"
                "Please adjust BOUNDARY_ZIP/BASECASE_ZIP to point to your CGMES zips."
            )
    net = cim2pp.from_cim(
        file_list=[str(boundary_zip), str(basecase_zip)],
        cgmes_version="2.4.15",
        use_GL_or_DL_profile="DL",
        run_powerflow=False,
    )
    pp.runpp(net, calculate_voltage_angles=True)
    return net


