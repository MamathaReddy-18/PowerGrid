            th_true_deg=np.rad2deg(th_true[trace_bus]),
            th_meas_deg=np.rad2deg(m_th[pmu_idx.index(trace_bus)]) if trace_bus in pmu_idx else np.nan,
            th_ukf_deg=np.rad2deg(th_est[trace_bus]),
            label=int(in_win),
        )
        rows.append(rec)

    return pd.DataFrame(rows), attack_windows

def plot_substation_trace(df_trace: pd.DataFrame, wins: list[tuple[int,int]]):
    t = df_trace["t"].to_numpy()
    fig, ax = plt.subplots(2, 1, figsize=(12,7), sharex=True)

    # |V|
    ax[0].plot(t, df_trace["V_true"], lw=2, label="True |V|")
    ax[0].plot(t, df_trace["V_meas"], ".", ms=3, label="PMU |V| (meas)")
    ax[0].plot(t, df_trace["V_ukf"], "--", lw=1.8, label="UKF |V|")
    for i,(a,b) in enumerate(wins): ax[0].axvspan(a,b, alpha=0.18, label="attack window" if i==0 else None)
    ax[0].set_title("Voltage Magnitude at Bus (Substation)")
    ax[0].set_ylabel("V (p.u.)"); ax[0].grid(True, alpha=0.3); ax[0].legend()

    # θ
    ax[1].plot(t, df_trace["th_true_deg"], lw=2, label="True θ")
    ax[1].plot(t, df_trace["th_meas_deg"], ".", ms=3, label="PMU θ (meas)")
    ax[1].plot(t, df_trace["th_ukf_deg"], "--", lw=1.8, label="UKF θ")
    for i,(a,b) in enumerate(wins): ax[1].axvspan(a,b, alpha=0.18, label="attack window" if i==0 else None)
    ax[1].set_xlabel("Time step")
    ax[1].set_ylabel("Angle (deg)"); ax[1].grid(True, alpha=0.3); ax[1].legend()

    plt.tight_layout(); plt.show()


