        for cg in [c for c in df.columns if c.startswith("Pgen_MW_bus")]:
            b = int(cg.split("bus")[-1]); target_gensP[b] = float(row[cg])
        target_vset  = {b:np.nan for b in range(NB)}
        for cv in [c for c in df.columns if c.startswith("Vset_pu_bus")]:
            b = int(cv.split("bus")[-1]); target_vset[b] = float(np.clip(row[cv], VSET_MIN, VSET_MAX))
        target_slackV = float(np.clip(row["Vset_pu_slack"], VSET_MIN, VSET_MAX)) if "Vset_pu_slack" in df.columns else np.nan

        # Apply & PF
        applied_loads, applied_gensP, applied_vset, applied_slackV, ok = robust_apply_and_solve(
            net, target_loads, target_gensP, target_vset, target_slackV,
