_DEF_GAP = DEBOUNCE_GAP

def _debounce(indices, gap=_DEF_GAP):
    out, last = [], -10**9
    for t in sorted(indices):
        if t - last >= gap:
            out.append(t); last = t
    return out

def _attack_windows_from_labels(dfx: pd.DataFrame):
    wins, t, y = [], dfx["t"].to_numpy(), dfx["label"].to_numpy().astype(int)
    if len(t) == 0: return wins
    start = None
    for i in range(len(t)):
        if y[i] == 1 and start is None:
            start = t[i]
        if (y[i] == 0 and start is not None) or (i == len(t)-1 and start is not None):
            end_t = t[i] if y[i] == 0 else (t[i] + 1)
            wins.append((int(start), int(end_t))); start = None
    return wins

def plot_panels(df_all: pd.DataFrame, sid: int, if_thr: float, hgb_thr: float | None = None):
    dfx = df_all[df_all.sim_id == sid].copy()
    t = dfx["t"].to_numpy(); wins = _attack_windows_from_labels(dfx)
    fig, ax = plt.subplots(3, 1, figsize=(12,9), sharex=True)
    chi = dfx["chi2"].to_numpy()
    base_mask = t <= PRETRAIN_END
    chi_thr = float(np.percentile(chi[base_mask], DET_PERC_GLOBAL)) if base_mask.any() else np.nan
    chi_dets = _debounce([int(tt) for tt, v in zip(t, chi) if (tt > PRETRAIN_END and np.isfinite(v) and v > chi_thr)], _DEF_GAP)
    ax[0].plot(t, chi, lw=2.0, label="χ² residual energy")
    for i,(a,b) in enumerate(wins): ax[0].axvspan(a,b,color="#5b9bd5",alpha=0.18,label="attack window" if i==0 else None)
    if np.isfinite(chi_thr): ax[0].axhline(chi_thr, ls="--", lw=1.6, color="#1f77b4", alpha=0.8, label=f"χ² thr p{DET_PERC_GLOBAL}")
    for i,tt in enumerate(chi_dets): ax[0].axvline(tt, color="#ff7f0e", lw=1.6, alpha=0.85, label="χ² detect" if i==0 else None)
    ax[0].set_title("Mahalanobis residual energy"); ax[0].set_ylabel("χ²"); ax[0].grid(True, alpha=0.3); ax[0].legend()
    if "if_score" in dfx.columns:
        if_score = dfx["if_score"].to_numpy()
        if_dets = _debounce([int(tt) for tt, s in zip(t, if_score) if (tt > PRETRAIN_END and s < if_thr)], _DEF_GAP)
        ax[1].plot(t, if_score, lw=2.0, label="IF score (higher=normal)")
        for i,(a,b) in enumerate(wins): ax[1].axvspan(a,b,color="#5b9bd5",alpha=0.18,label="attack window" if i==0 else None)
        ax[1].axhline(if_thr, ls="--", lw=1.6, color="#9467bd", alpha=0.9, label="IF threshold")
        for i,tt in enumerate(if_dets): ax[1].axvline(tt, color="#8a2be2", lw=1.6, alpha=0.85, label="IF detect" if i==0 else None)
        ax[1].set_ylabel("IF score"); ax[1].grid(True, alpha=0.3); ax[1].legend()
    else:
        ax[1].axis("off")
    if "hgb_proba" in dfx.columns:
        hgb = dfx["hgb_proba"].to_numpy()
        if hgb_thr is None:
            hgb_thr = float(np.percentile(hgb[t <= PRETRAIN_END], DET_PERC_GLOBAL)) if (t <= PRETRAIN_END).any() else 0.5
        hgb_dets = _debounce([int(tt) for tt, p in zip(t, hgb) if (tt > PRETRAIN_END and p > hgb_thr)], _DEF_GAP)
        ax[2].plot(t, hgb, lw=2.0, label="HGB P(attack)")
        for i,(a,b) in enumerate(wins): ax[2].axvspan(a,b,color="#5b9bd5",alpha=0.18,label="attack window" if i==0 else None)
        ax[2].axhline(hgb_thr, ls="--", lw=1.6, color="#2ca02c", alpha=0.9, label="HGB threshold")
        for i,tt in enumerate(hgb_dets): ax[2].axvline(tt, color="#2ca02c", lw=1.6, alpha=0.85, label="HGB detect" if i==0 else None)
        ax[2].set_xlabel("Time step"); ax[2].set_ylabel("P(attack)"); ax[2].grid(True, alpha=0.3); ax[2].legend()
    else:
        ax[2].axis("off")
    plt.tight_layout(); plt.show()

def run_single_sim_trace(sim_id, df, base_net, pmu_buses, main_sub, input_indexers, rng, trace_bus):
    net = base_net.deepcopy()
    NB = net.bus.shape[0]
    slack_bus = int(net.ext_grid.bus.iloc[0]) if len(net.ext_grid) else 0
    dim_x = (NB - 1) + NB
    points = MerweScaledSigmaPoints(n=dim_x, alpha=ALPHA, beta=BETA, kappa=KAPPA)
    pmu_idx = [int(b) for b in pmu_buses]
    def hx(x):
        th, vm = state_unpack(x, NB, slack_bus)
        return np.concatenate([th[pmu_idx], vm[pmu_idx]])
    nθ = len(pmu_idx); nV = len(pmu_idx); dim_z = nθ + nV
    R = np.zeros((dim_z, dim_z))
    s_ang = np.deg2rad(PMU_SIGMA_VANG_DEG)
    for k in range(nθ): R[k,k] = s_ang**2
    for k in range(nθ, nθ+nV): R[k,k] = PMU_SIGMA_VMAG_PU**2
    Qx = np.eye(dim_x)
    for i in range(NB-1): Qx[i,i] = Q_ANGLE_RAD**2
    for j in range(NB):   Qx[(NB-1)+j,(NB-1)+j] = Q_VMAG_PU**2
    P0 = np.eye(dim_x)
    for i in range(NB-1): P0[i,i] = P0_ANGLE_RAD**2
    for j in range(NB):   P0[(NB-1)+j,(NB-1)+j] = P0_VMAG_PU**2
    P0 = nearest_spd(P0 + 1e-9*np.eye(dim_x), 1e-9)

    G_t = np.zeros((dim_x, 1), dtype=float)
    current_du = None
    def fx_sens(x, dt):
        x2 = x if current_du is None else (x + G_t.dot(current_du))
        return clip_and_wrap_state(x2.copy(), NB, slack_bus)

    ukf = UKF(dim_x=dim_x, dim_z=dim_z, fx=fx_sens, hx=hx, dt=DT, points=points)
    pp.runpp(net, calculate_voltage_angles=True)
    ukf.x = clip_and_wrap_state(state_pack_from_pf(
        net.res_bus.vm_pu.values.astype(float),
        net.res_bus.va_degree.values.astype(float), NB, slack_bus), NB, slack_bus)
    ukf.P, ukf.Q, ukf.R = P0.copy(), Qx.copy(), R.copy()
    ukf.x_mean_fn = state_mean_fn_factory(np.arange(NB-1, dtype=int))
    ukf.residual_x = residual_fn_factory(np.arange(NB-1, dtype=int))
    ukf.residual_z = residual_fn_factory(np.arange(nθ, dtype=int))

    a0, b0 = ATTACK_WINDOW_BASE
    jitter = int(rng.integers(-5, 6)); a = max(10, a0 + jitter); b = min(MAX_SECONDS - 1, a + (b0 - a0) + 5)
    u_prev = None
    prev_loads, prev_gensP, prev_vset, prev_slackV = capture_current_inputs(net)
    rows = []

    for _, row in df.iterrows():
        t = int(row["time_s"])
        target_loads = {b: prev_loads[b] for b in range(NB)}
        for cP in [c for c in df.columns if c.startswith("P_MW_bus")]:
            b = int(cP.split("bus")[-1]); target_loads[b] = (float(row[cP]), target_loads[b][1])
        for cQ in [c for c in df.columns if c.startswith("Q_MVAr_bus")]:
            b = int(cQ.split("bus")[-1]); target_loads[b] = (target_loads[b][0], float(row[cQ]))
        target_gensP = {b: prev_gensP[b] for b in range(NB)}
        for cg in [c for c in df.columns if c.startswith("Pgen_MW_bus")]:
            b = int(cg.split("bus")[-1]); target_gensP[b] = float(row[cg])
        target_vset  = {b: prev_vset[b] for b in range(NB)}
        for cv in [c for c in df.columns if c.startswith("Vset_pu_bus")]:
            b = int(cv.split("bus")[-1]); target_vset[b] = float(np.clip(row[cv], VSET_MIN, VSET_MAX))
        target_slackV = float(np.clip(row["Vset_pu_slack"], VSET_MIN, VSET_MAX)) if "Vset_pu_slack" in df.columns else prev_slackV

        applied_loads, applied_gensP, applied_vset, applied_slackV, ok = robust_apply_and_solve(
            net, target_loads, target_gensP, target_vset, target_slackV,
            prev_loads, prev_gensP, prev_vset, prev_slackV
        )
        if ok:
            prev_loads, prev_gensP, prev_vset, prev_slackV = applied_loads, applied_gensP, applied_vset, applied_slackV

        vm_true = net.res_bus.vm_pu.values.astype(float)
        th_true = np.deg2rad(net.res_bus.va_degree.values.astype(float))
        m_vm = vm_true[pmu_buses].copy() + np.random.normal(0.0, PMU_SIGMA_VMAG_PU, size=len(pmu_buses))
        m_th = wrap_angle(th_true[pmu_buses] + np.random.normal(0.0, np.deg2rad(PMU_SIGMA_VANG_DEG), size=len(pmu_buses)))

        in_win = (a <= t < b)
        if in_win:
            win_len = max(1, b - a); frac = (t - a + 1)/win_len
            drift_rad = np.deg2rad(ANGLE_SHIFT_DEG_FINAL * frac)
            sub_mask = np.isin(pmu_buses, main_sub)
            m_th[sub_mask] = wrap_angle(m_th[sub_mask] + drift_rad)
            m_vm[sub_mask] = m_vm[sub_mask] * V_SCALE

        z_t = np.concatenate([m_th, m_vm])
        ukf.P = nearest_spd(ukf.P, 1e-9); ukf.predict()
        ukf.x = clip_and_wrap_state(ukf.x, NB, slack_bus)
        ukf.P = nearest_spd(ukf.P, 1e-9); ukf.update(z_t)
        ukf.x = clip_and_wrap_state(ukf.x, NB, slack_bus)
        ukf.P = nearest_spd(ukf.P, 1e-9)

        th_est, vm_est = state_unpack(ukf.x, NB, slack_bus)
        rows.append(dict(
            t=t,
            V_true=vm_true[trace_bus],
            V_meas=m_vm[pmu_buses.index(trace_bus)] if trace_bus in pmu_buses else np.nan,
            V_ukf=vm_est[trace_bus],
