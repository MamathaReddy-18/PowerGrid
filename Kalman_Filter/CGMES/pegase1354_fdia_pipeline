        target_slackV = prev_slackV
        if has_slack and not pd.isna(row["Vset_pu_slack"]):
            target_slackV = float(np.clip(row["Vset_pu_slack"], VSET_MIN, VSET_MAX))

        applied_loads, applied_gensP, applied_vset, applied_slackV, ok = robust_apply_and_solve(
            net, target_loads, target_gensP, target_vset, target_slackV,
            prev_loads, prev_gensP, prev_vset, prev_slackV
        )
        if ok:
            prev_loads, prev_gensP, prev_vset, prev_slackV = applied_loads, applied_gensP, applied_vset, applied_slackV

        success = bool(ok)
        if success:
            p_loss = float(net.res_line.pl_mw.sum() + net.res_trafo.pl_mw.sum())
            q_loss = float(net.res_line.ql_mvar.sum() + net.res_trafo.ql_mvar.sum())
            max_loading = float(pd.concat([net.res_line.loading_percent, net.res_trafo.loading_percent], axis=0).max())
        else:
            p_loss = float("nan"); q_loss = float("nan"); max_loading = float("nan")

        summary_rows.append(dict(time_s=t, success=success, p_loss_mw=p_loss, q_loss_mvar=q_loss, max_loading_percent=max_loading))
        if success:
            vm, va = net.res_bus.vm_pu.values, net.res_bus.va_degree.values
            bus_idx = np.arange(NB, dtype=int)
            bus_records.append(pd.DataFrame({"time_s": t, "bus": bus_idx, "vm_pu": vm, "va_degree": va}))

    pd.DataFrame(summary_rows).to_csv(OUT_DIR / "pf_timeseries_summary.csv", index=False)
    if bus_records:
        pd.concat(bus_records, ignore_index=True).to_parquet(OUT_DIR / "pf_bus_timeseries.parquet", index=False)
    print("[PF] Wrote pf_timeseries_summary.csv and pf_bus_timeseries.parquet")

def task_run_ukf(args):
    csv_path = Path(args.csv or "pegase1354_timeseries.csv")
    if not csv_path.is_file(): raise FileNotFoundError(csv_path)
    df = pd.read_csv(csv_path).sort_values("time_s").reset_index(drop=True)
    net = build_pegase1354_net()
    if not try_runpp_nr_first(net):
        raise RuntimeError("Could not get a feasible base point on PEGASE.")
    if Path("pmu_buses.txt").exists():
        pmu_buses = list(map(int, Path("pmu_buses.txt").read_text().split(",")))
        main_sub = list(map(int, Path("main_sub.txt").read_text().split(","))) if Path("main_sub.txt").exists() else []
    else:
        pmu_buses, main_sub = choose_pmu_buses(net)

    load_p_cols = sorted([c for c in df.columns if c.startswith("P_MW_bus")], key=lambda s: int(s.split("bus")[-1]))
    load_q_cols = sorted([c for c in df.columns if c.startswith("Q_MVAr_bus")], key=lambda s: int(s.split("bus")[-1]))
    gen_p_cols  = sorted([c for c in df.columns if c.startswith("Pgen_MW_bus")], key=lambda s: int(s.split("bus")[-1]))
    vset_cols   = sorted([c for c in df.columns if c.startswith("Vset_pu_bus")], key=lambda s: int(s.split("bus")[-1]))
    has_slack   = "Vset_pu_slack" in df.columns
    slack_bus0  = int(net.ext_grid.bus.iloc[0]) if len(net.ext_grid) else 0
    input_indexers = build_input_indexers(load_p_cols, load_q_cols, gen_p_cols, vset_cols, has_slack, slack_bus0)

    N_SIMS = int(args.nsims or 5)
    all_df = []
    for s in range(N_SIMS):
        sim_rng = np.random.default_rng(BASE_SEED + s)
        dfi = run_single_sim(s, df, net, pmu_buses, main_sub, input_indexers, sim_rng)
        all_df.append(dfi)
    df_all = pd.concat(all_df, axis=0, ignore_index=True)
    if_model, if_thr, df_all = train_isolation_forest(df_all)
    hgb_model, hgb_thr, df_all = train_histgb_classifier(df_all)
    df_all.to_csv("fdia_ukf_iforest_hgb_timeseries.csv", index=False)
    Path("thresholds.txt").write_text(f"IF:{if_thr}\nHGB:{hgb_thr}\n")
    print("[UKF/ML] Saved fdia_ukf_iforest_hgb_timeseries.csv and thresholds.txt")

def task_plot_panels(args):
