def task_plot_trace(args):
    csv_path = Path(args.csv or "pegase1354_timeseries.csv")
    df = pd.read_csv(csv_path).sort_values("time_s").reset_index(drop=True)
    net = build_pegase1354_net()
    if not try_runpp_nr_first(net):
        raise RuntimeError("Could not get a feasible base point on PEGASE.")
    if Path("pmu_buses.txt").exists():
        pmu_buses = list(map(int, Path("pmu_buses.txt").read_text().split(",")))
        main_sub = list(map(int, Path("main_sub.txt").read_text().split(","))) if Path("main_sub.txt").exists() else []
    else:
        pmu_buses, main_sub = choose_pmu_buses(net)
    slack_bus = int(net.ext_grid.bus.iloc[0]) if len(net.ext_grid) else 0
    trace_bus = main_sub[0] if len(main_sub) else (pmu_buses[0] if pmu_buses else (slack_bus if slack_bus in pmu_buses else 0))
    sim_rng = np.random.default_rng(BASE_SEED + 777)
    idxs = build_input_indexers(
        [c for c in df.columns if c.startswith("P_MW_bus")],
        [c for c in df.columns if c.startswith("Q_MVAr_bus")],
        [c for c in df.columns if c.startswith("Pgen_MW_bus")],
        [c for c in df.columns if c.startswith("Vset_pu_bus")],
        "Vset_pu_slack" in df.columns,
        slack_bus
    )
    df_trace, wins = run_single_sim_trace(
        sim_id=999, df=df, base_net=net,
        pmu_buses=pmu_buses, main_sub=main_sub,
        input_indexers=idxs, rng=sim_rng, trace_bus=trace_bus
    )
    plot_substation_trace(df_trace, wins)


