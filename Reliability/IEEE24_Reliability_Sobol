# ==================== Helper Functions ====================

def rates_from_FOR_MTTR(FOR: float, mttr_h: float) -> Tuple[float, float]:
    """
    Convert FOR and MTTR to:
      lambda = failure rate per hour
      mu     = repair rate per hour
    """
    FOR = np.clip(FOR, 0.0, 0.999999)
    mu = 1.0 / max(mttr_h, 1e-9)
    lam = (FOR * mu) / (1.0 - FOR + EPS)
    return lam, mu


def rates_from_lambdaP_duration(lambda_p_per_year: float, dur_h: float) -> Tuple[float, float]:
    """
    Convert line permanent outage rate (per year) and repair duration (hours)
    into:
      lambda = failure rate per hour
      mu     = repair rate per hour
    """
    lam = lambda_p_per_year / HOURS_PER_YEAR
    mu = 1.0 / max(dur_h, 1e-9)
    return lam, mu


def weibull_scale_from_mean(mean_speed: float, k: float) -> float:
    """Compute Weibull scale from mean speed and shape k."""
    return mean_speed / gamma(1.0 + 1.0 / k)


def wind_power_cf(v: float, v_ci: float = 3.0, v_rated: float = 12.0,
                  v_co: float = 25.0, cubic: bool = True) -> float:
    """Simple wind power capacity factor."""
    if v < v_ci or v >= v_co:
        return 0.0
    if v >= v_rated:
        return 1.0
    x = (v - v_ci) / (v_rated - v_ci)
    return x**3 if cubic else x


def lognormal_multiplier_from_z(z: float, sigma: float) -> float:
    """Lognormal load multiplier with mean 1."""
    return float(np.exp(sigma * z - 0.5 * sigma * sigma))


def stable_seed(base_seed: int, *parts) -> int:
    """Stable deterministic seed independent of Python hash randomization."""
    h = hashlib.sha256(str((base_seed,) + parts).encode("utf-8")).hexdigest()
    return int(h[:16], 16) % (2**32 - 1)


def clamp_prob(x: float) -> float:
    """Clamp probability-like quantity to (0,1)."""
    return float(np.clip(x, 1e-6, 1.0 - 1e-6))


def clamp_pos(x: float, floor: float = 1e-9) -> float:
    """Clamp positive quantity away from zero."""
    return float(max(x, floor))


