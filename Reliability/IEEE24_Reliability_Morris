# Colour-code dots by parameter type so you can spot patterns instantly
_TYPE_COLORS = {
    "gen_physical":  "#E74C3C",   # red   — generator physical rates (lambda_f, lambda_p, mu)
    "gen_cyber":     "#E67E22",   # orange — generator cyber rates (lambda_A, theta, mu_M, mu_R, mu_p)
    "line_physical": "#2980B9",   # blue  — line physical rates
    "line_cyber":    "#1ABC9C",   # teal  — line cyber rates
    "wind_load":     "#8E44AD",   # purple — wind_k, wind_mean, load_sigma
}

_PHYSICAL_KEYS = {"lambda_f", "lambda_p", "mu"}
_CYBER_KEYS    = {"lambda_A", "theta", "mu_M", "mu_R", "mu_p"}


def _param_color(name: str) -> str:
    if name in ("wind_k", "wind_mean", "load_sigma"):
        return _TYPE_COLORS["wind_load"]
    for rate in _PHYSICAL_KEYS:
        if f"_{rate}_" in name or name.endswith(f"_{rate}"):
            if "_G" in name:
                return _TYPE_COLORS["gen_physical"]
            else:
                return _TYPE_COLORS["line_physical"]
    for rate in _CYBER_KEYS:
        if f"_{rate}_" in name or name.endswith(f"_{rate}"):
            if "_G" in name:
                return _TYPE_COLORS["gen_cyber"]
            else:
                return _TYPE_COLORS["line_cyber"]
    return "#7F8C8D"


def _plot_mu_star_sigma(df, mu_star, sigma, title, xlabel, ylabel, thresh, out_path):
    fig, ax = plt.subplots(figsize=(10, 8))

    colors = [_param_color(n) for n in df["parameter"].tolist()]

    # All dots (small, semi-transparent)
    ax.scatter(mu_star, sigma, c=colors, alpha=0.35, s=18, linewidths=0)

    # Threshold vertical line
    ax.axvline(thresh, color="black", linestyle="--", linewidth=1.2,
               label=f"Threshold (μ* = {thresh:.4f})")

    # Label top-15 by μ*
    top15_idx = np.argsort(-mu_star)[:15]
    for idx in top15_idx:
        name = df["parameter"].iloc[idx]
        ax.annotate(
            name,
            xy=(mu_star[idx], sigma[idx]),
            fontsize=6.5,
            ha="left", va="bottom",
            xytext=(3, 3), textcoords="offset points",
        )
        ax.scatter(mu_star[idx], sigma[idx],
                   c=colors[idx], s=50, zorder=5, linewidths=0.5, edgecolors="k")

    # Legend for colours
    patches = [
        mpatches.Patch(color=v, label=k.replace("_", " ").title())
        for k, v in _TYPE_COLORS.items()
    ]
    patches.append(
        mpatches.Patch(color="none", label=f"Threshold line", linestyle="--")
    )
    ax.legend(handles=patches, fontsize=8, loc="upper left", framealpha=0.8)

    ax.set_xlabel(xlabel, fontsize=11)
    ax.set_ylabel(ylabel, fontsize=11)
    ax.set_title(title, fontsize=12, fontweight="bold")
    ax.grid(True, alpha=0.25)

    plt.tight_layout()
    plt.savefig(out_path, dpi=150)
    plt.close()
    print(f"      Saved: {out_path}")


def _plot_top_bar(df, out_path, top_n=40):
    top = df.head(top_n).copy()
    params = top["parameter"].tolist()
    y = np.arange(len(params))

    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, max(8, top_n * 0.28)))

    colors = [_param_color(p) for p in params]

    # LOLP
    ax1.barh(y, top["mu_star_LOLP"], color=colors, alpha=0.85, height=0.7)
    ax1.set_yticks(y)
    ax1.set_yticklabels(params, fontsize=7)
    ax1.invert_yaxis()
    ax1.set_xlabel("μ* (LOLP)", fontsize=10)
    ax1.set_title(f"Top {top_n} — LOLP", fontsize=11, fontweight="bold")
    ax1.grid(axis="x", alpha=0.3)

    # EENS — re-sort by EENS for this panel
    top_eens = df.nsmallest(top_n, "rank_EENS").copy()
    params_e = top_eens["parameter"].tolist()
    colors_e = [_param_color(p) for p in params_e]
    ye = np.arange(len(params_e))

    ax2.barh(ye, top_eens["mu_star_EENS"], color=colors_e, alpha=0.85, height=0.7)
    ax2.set_yticks(ye)
    ax2.set_yticklabels(params_e, fontsize=7)
    ax2.invert_yaxis()
    ax2.set_xlabel("μ* (EENS)  [MWh/yr per unit]", fontsize=10)
    ax2.set_title(f"Top {top_n} — EENS", fontsize=11, fontweight="bold")
    ax2.grid(axis="x", alpha=0.3)

    # Shared colour legend
    patches = [
        mpatches.Patch(color=v, label=k.replace("_", " ").title())
        for k, v in _TYPE_COLORS.items()
    ]
    fig.legend(handles=patches, fontsize=8, loc="lower center",
               ncol=3, bbox_to_anchor=(0.5, -0.01), framealpha=0.9)

    plt.suptitle("Morris Screening — Top Parameters by μ*\nRTS-96 Cyber-Physical Reliability",
                 fontsize=12, fontweight="bold", y=1.01)
    plt.tight_layout()
    plt.savefig(out_path, dpi=150, bbox_inches="tight")
    plt.close()
    print(f"      Saved: {out_path}")


