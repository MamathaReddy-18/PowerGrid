def evaluate_single(args_tuple):
    """
    Evaluate one Morris sample row.
    Called by the parallel worker pool — must be a top-level function
    (pickle-able) so ProcessPoolExecutor can ship it to worker processes.

    Parameters
    ----------
    args_tuple : (i, row, param_names, max_outages, enum_top_lines,
                  inner_trials, base_seed)

    Returns
    -------
    (i, lolp, eens)
    """
    (i, row, param_names, max_outages, enum_top_lines, inner_trials, base_seed) = args_tuple

    # Build the params dict exactly as compute_reliability expects
    params = {name: float(row[j]) for j, name in enumerate(param_names)}

    # Derived quantity that compute_reliability needs
    params["wind_scale"] = weibull_scale_from_mean(
        params["wind_mean"], params["wind_k"]
    )

    sample_seed = stable_seed(base_seed, "morris", i)

    lolp, eens, *_ = compute_reliability(
        params=params,
        max_outages=max_outages,
        enum_top_lines=enum_top_lines,
        inner_trials=inner_trials,
        seed=sample_seed,
    )
    return (i, float(lolp), float(eens))


# ══════════════════════════════════════════════════════════════════════════════
# MORRIS ANALYSIS
# ══════════════════════════════════════════════════════════════════════════════

def run_morris(
    n_trajectories: int,
    inner_trials: int,
    max_outages: int,
    enum_top_lines: int,
    n_jobs: int,
    seed: int,
    num_levels: int,
    threshold_percentile: float,
    output_dir: str,
):
    os.makedirs(output_dir, exist_ok=True)

    # ── Build problem (same 563 dimensions as Sobol) ─────────────────────────
    problem = build_sobol_problem()
    D = problem["num_vars"]
    n_eval = n_trajectories * (D + 1)

    print("=" * 70)
    print("Morris Elementary Effects Screening — RTS-96 CPPS")
    print("=" * 70)
    print(f"  Parameters (D)        : {D}")
    print(f"  Trajectories (r)      : {n_trajectories}")
    print(f"  Evaluations (r×(D+1)) : {n_eval}")
    print(f"  Inner MC trials       : {inner_trials}")
    print(f"  Enum top lines        : {enum_top_lines}")
    print(f"  Parallel workers      : {n_jobs}")
    print(f"  Output directory      : {output_dir}/")
    print("=" * 70)

    # ── Generate Morris sample matrix ─────────────────────────────────────────
    print("\n[1/4] Generating Morris trajectories...")
    rng_seed = seed % (2**31 - 1)
    X = morris_sample(
        problem,
        N=n_trajectories,
        num_levels=num_levels,
        seed=rng_seed,
    )
    print(f"      Sample matrix shape: {X.shape}  ({X.shape[0]} rows × {X.shape[1]} params)")

    # ── Evaluate model ─────────────────────────────────────────────────────────
    print(f"\n[2/4] Evaluating model ({n_eval} runs)...")

    Y_lolp = np.full(n_eval, np.nan)
    Y_eens = np.full(n_eval, np.nan)

    t0 = time.time()

    tasks = [
        (i, X[i], problem["names"], max_outages, enum_top_lines, inner_trials, seed)
        for i in range(n_eval)
    ]

    completed = 0
    errors = 0

    if n_jobs == 1:
        # Sequential — easier to debug
        for task in tasks:
            try:
                idx, lolp, eens = evaluate_single(task)
                Y_lolp[idx] = lolp
                Y_eens[idx] = eens
            except Exception as exc:
                errors += 1
                print(f"      [WARN] sample {task[0]} failed: {exc}")
            completed += 1
            if completed % 50 == 0 or completed == n_eval:
                elapsed = time.time() - t0
                rate = completed / elapsed
                eta = (n_eval - completed) / rate if rate > 0 else 0
                print(
                    f"      {completed}/{n_eval}  "
                    f"elapsed {elapsed/60:.1f}m  "
                    f"ETA {eta/60:.1f}m"
                )
    else:
        # Parallel
        with ProcessPoolExecutor(max_workers=n_jobs) as executor:
            futures = {executor.submit(evaluate_single, t): t[0] for t in tasks}
            for fut in as_completed(futures):
                try:
                    idx, lolp, eens = fut.result()
                    Y_lolp[idx] = lolp
                    Y_eens[idx] = eens
                except Exception as exc:
                    errors += 1
                    print(f"      [WARN] sample failed: {exc}")
                completed += 1
                if completed % 100 == 0 or completed == n_eval:
                    elapsed = time.time() - t0
                    rate = completed / elapsed
                    eta = (n_eval - completed) / rate if rate > 0 else 0
                    print(
                        f"      {completed}/{n_eval}  "
                        f"elapsed {elapsed/60:.1f}m  "
                        f"ETA {eta/60:.1f}m"
                    )

    elapsed_total = time.time() - t0
    print(f"\n      Done in {elapsed_total/60:.1f} min  ({errors} errors)")

    # Replace NaN from failed evaluations with column medians
    if np.any(np.isnan(Y_lolp)):
        Y_lolp = np.where(np.isnan(Y_lolp), np.nanmedian(Y_lolp), Y_lolp)
    if np.any(np.isnan(Y_eens)):
        Y_eens = np.where(np.isnan(Y_eens), np.nanmedian(Y_eens), Y_eens)

    # ── Morris analysis ───────────────────────────────────────────────────────
    print("\n[3/4] Computing Morris indices...")

    Si_lolp = morris_analyze.analyze(
        problem, X, Y_lolp,
        num_resamples=100,
        conf_level=0.95,
        print_to_console=False,
        num_levels=num_levels,
        seed=rng_seed,
    )
    Si_eens = morris_analyze.analyze(
        problem, X, Y_eens,
        num_resamples=100,
        conf_level=0.95,
        print_to_console=False,
        num_levels=num_levels,
        seed=rng_seed,
    )

    mu_star_lolp = np.array(Si_lolp["mu_star"])
    sigma_lolp   = np.array(Si_lolp["sigma"])
    mu_star_eens = np.array(Si_eens["mu_star"])
    sigma_eens   = np.array(Si_eens["sigma"])

    # ── Rank and summarise ────────────────────────────────────────────────────
    rank_lolp = np.argsort(-mu_star_lolp) + 1   # 1 = most influential
    rank_eens = np.argsort(-mu_star_eens) + 1

    results_df = pd.DataFrame({
        "parameter":     problem["names"],
        "mu_star_LOLP":  mu_star_lolp,
        "sigma_LOLP":    sigma_lolp,
        "rank_LOLP":     rank_lolp,
        "mu_star_EENS":  mu_star_eens,
        "sigma_EENS":    sigma_eens,
        "rank_EENS":     rank_eens,
    })
    results_df = results_df.sort_values("mu_star_LOLP", ascending=False).reset_index(drop=True)

    csv_path = os.path.join(output_dir, "morris_results.csv")
    results_df.to_csv(csv_path, index=False)
    print(f"      Saved: {csv_path}")

    # ── Determine active (important) parameters ────────────────────────────────
    # A parameter is "active" if its μ* is above the threshold percentile
    # in EITHER the LOLP ranking OR the EENS ranking.
    thresh_lolp = np.percentile(mu_star_lolp, threshold_percentile)
    thresh_eens = np.percentile(mu_star_eens, threshold_percentile)

    active_mask = (mu_star_lolp >= thresh_lolp) | (mu_star_eens >= thresh_eens)
    active_params = [name for name, active in zip(problem["names"], active_mask) if active]

    # Always keep the 3 wind/load parameters regardless of threshold
    for p in ["wind_k", "wind_mean", "load_sigma"]:
        if p not in active_params:
            active_params.append(p)

    inactive_params = [p for p in problem["names"] if p not in active_params]

    print(f"\n      Threshold percentile : {threshold_percentile:.0f}th")
    print(f"      Active parameters    : {len(active_params)}  (will be varied in Sobol)")
    print(f"      Inactive parameters  : {len(inactive_params)}  (fixed at multiplier = 1.0)")

    # Save active parameter list
    active_info = {
        "n_active":           len(active_params),
        "n_inactive":         len(inactive_params),
        "threshold_pct_lolp": float(thresh_lolp),
        "threshold_pct_eens": float(thresh_eens),
        "active_params":      active_params,
        "inactive_params":    inactive_params,
    }
    json_path = os.path.join(output_dir, "morris_active_params.json")
    with open(json_path, "w") as f:
        json.dump(active_info, f, indent=2)
    print(f"      Saved: {json_path}")

    # Print top 20 for each metric
    print("\n" + "─" * 70)
    print("TOP 20 PARAMETERS — LOLP (by μ*)")
    print("─" * 70)
    print(f"{'Rank':>4}  {'Parameter':<28}  {'μ* (LOLP)':>12}  {'σ (LOLP)':>12}")
    top20_lolp = results_df.nsmallest(20, "rank_LOLP")
    for _, r in top20_lolp.iterrows():
        print(f"  {int(r.rank_LOLP):>3}  {r.parameter:<28}  {r.mu_star_LOLP:>12.6f}  {r.sigma_LOLP:>12.6f}")

    print("\n" + "─" * 70)
    print("TOP 20 PARAMETERS — EENS (by μ*)")
    print("─" * 70)
    print(f"{'Rank':>4}  {'Parameter':<28}  {'μ* (EENS)':>12}  {'σ (EENS)':>12}")
    top20_eens = results_df.nsmallest(20, "rank_EENS")
    for _, r in top20_eens.iterrows():
        print(f"  {int(r.rank_EENS):>3}  {r.parameter:<28}  {r.mu_star_EENS:>12.6f}  {r.sigma_EENS:>12.6f}")

    # ── Plots ─────────────────────────────────────────────────────────────────
    print("\n[4/4] Generating plots...")
    _plot_mu_star_sigma(
        results_df, mu_star_lolp, sigma_lolp,
        title="Morris Screening — LOLP\n(μ* = mean absolute elementary effect)",
        xlabel="μ* (LOLP)", ylabel="σ (LOLP)",
        thresh=thresh_lolp,
        out_path=os.path.join(output_dir, "morris_mu_star_lolp.png"),
    )
    _plot_mu_star_sigma(
        results_df, mu_star_eens, sigma_eens,
        title="Morris Screening — EENS\n(μ* = mean absolute elementary effect)",
        xlabel="μ* (EENS)  [MWh/yr per unit]", ylabel="σ (EENS)",
        thresh=thresh_eens,
        out_path=os.path.join(output_dir, "morris_mu_star_eens.png"),
    )
    _plot_top_bar(
        results_df,
        out_path=os.path.join(output_dir, "morris_top_bar.png"),
    )

    print(f"\n{'='*70}")
    print("SUMMARY")
    print(f"{'='*70}")
    print(f"  Total evaluations run  : {n_eval}")
    print(f"  Wall time              : {elapsed_total/60:.1f} min")
    print(f"  Active parameters      : {len(active_params)} / {D}")
    print(f"  Dimension reduction    : {D} → {len(active_params)} ({100*(D - len(active_params))/D:.0f}% cut)")
    print(f"\n  Sobol cost (original)  : N × {D+2} evaluations per sample")
    print(f"  Sobol cost (reduced)   : N × {len(active_params)+2} evaluations per sample")
    reduction_factor = (D + 2) / (len(active_params) + 2)
    print(f"  Speed-up factor        : {reduction_factor:.1f}×")
    print(f"\n  Next step:")
    print(f"  python rts96_sobol.py --mode reduced \\")
    print(f"         --active-params {json_path} \\")
    print(f"         --n-samples 512 --inner-trials 50 --enum-top-lines 8")
    print(f"{'='*70}\n")

    return results_df, active_params


