# REDUCED SOBOL HELPER  (bonus — build the reduced-dimension Sobol problem)
# ══════════════════════════════════════════════════════════════════════════════

def build_reduced_sobol_problem(active_params_json: str) -> dict:
    """
    Build a SALib problem dict using only the active parameters identified
    by Morris screening.  Inactive parameters will be fixed at 1.0 (nominal).

    Usage (from your Sobol script):
        from morris_screening import build_reduced_sobol_problem
        problem = build_reduced_sobol_problem("morris_output/morris_active_params.json")
        # then use problem with saltelli.sample() as normal
    """
    with open(active_params_json) as f:
        info = json.load(f)

    full_problem = build_sobol_problem()
    full_bounds  = dict(zip(full_problem["names"], full_problem["bounds"]))

    active = info["active_params"]
    return {
        "num_vars": len(active),
        "names":    active,
        "bounds":   [full_bounds[p] for p in active],
    }


def expand_params_with_inactive(
    reduced_params: Dict[str, float],
    active_params_json: str,
) -> Dict[str, float]:
    """
    Given a dict of active-parameter values (from the reduced Sobol sample),
    fill in all inactive parameters at their nominal multiplier = 1.0 so that
    compute_reliability() receives the full 563-parameter dict it expects.

    Usage (from your Sobol evaluation loop):
        from morris_screening import expand_params_with_inactive
        full_params = expand_params_with_inactive(reduced_row, json_path)
        full_params["wind_scale"] = weibull_scale_from_mean(...)
        lolp, eens, ... = compute_reliability(full_params, ...)
    """
    with open(active_params_json) as f:
        info = json.load(f)

    full_params = {p: 1.0 for p in info["inactive_params"]}
    full_params.update(reduced_params)
    return full_params


