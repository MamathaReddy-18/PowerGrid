def main():
    parser = argparse.ArgumentParser(
        description="Morris screening for RTS-96 563D cyber-physical reliability model",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument("--trajectories", type=int, default=20,
                        help="Number of Morris trajectories r. Cost = r × (D+1). Default: 20.")
    parser.add_argument("--inner-trials", type=int, default=50,
                        help="Inner MC trials per contingency. Default: 50.")
    parser.add_argument("--max-outages", type=int, default=1,
                        help="Max outage order. Default: 1.")
    parser.add_argument("--enum-top-lines", type=int, default=8,
                        help="Top lines to enumerate. Default: 8.")
    parser.add_argument("--n-jobs", type=int, default=1,
                        help="Parallel workers. Set to CPU count on ACCRE. Default: 1.")
    parser.add_argument("--seed", type=int, default=42,
                        help="Base random seed. Default: 42.")
    parser.add_argument("--num-levels", type=int, default=4,
                        help="Number of levels in Morris grid. Default: 4.")
    parser.add_argument("--threshold-percentile", type=float, default=75.0,
                        help="μ* percentile cutoff to classify a param as active. Default: 75.")
    parser.add_argument("--output-dir", type=str, default="morris_output",
                        help="Directory for all output files. Default: morris_output/")

    args = parser.parse_args()

    run_morris(
        n_trajectories=args.trajectories,
        inner_trials=args.inner_trials,
        max_outages=args.max_outages,
        enum_top_lines=args.enum_top_lines,
        n_jobs=args.n_jobs,
        seed=args.seed,
        num_levels=args.num_levels,
        threshold_percentile=args.threshold_percentile,
        output_dir=args.output_dir,
    )


if __name__ == "__main__":
    main()